# SQLite：路径相对 `prisma/schema.prisma` 所在目录（即 `web/prisma/dev.db`）
DATABASE_URL="file:./dev.db"

# —— LLM provider（任选其一；同时配置时按 ANTHROPIC > DEEPSEEK > OPENAI 自动挑） ——
# 显式锁定 provider（可选）：anthropic | deepseek | openai
# LLM_PROVIDER=anthropic

# —— Anthropic Claude（在 https://console.anthropic.com/ 拿 sk-ant- 开头的 key） ——
# ANTHROPIC_API_KEY=sk-ant-...
# 可选：自定义 endpoint
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# 模型名（默认 claude-sonnet-4-5）；备选 claude-opus-4-5 / claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-5

# —— DeepSeek（OpenAI 兼容协议） ——
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# —— OpenAI 官方 ——
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# 统一覆盖模型名（最高优先级；不设时按 provider 各自的 *_MODEL，再回到内置默认）
# LLM_MODEL=claude-sonnet-4-5
