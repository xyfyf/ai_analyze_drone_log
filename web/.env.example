# SQLite：路径相对 `prisma/schema.prisma` 所在目录（即 `web/prisma/dev.db`）
DATABASE_URL="file:./dev.db"

# —— LLM（二选一或同时只生效一个：优先 DeepSeek）——
# DeepSeek（OpenAI 兼容）：在本地 web/.env 填写，勿提交 git
# DEEPSEEK_API_KEY=
# 可选，默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI 官方
# OPENAI_API_KEY=
# 可选自定义网关
# OPENAI_BASE_URL=

# 统一覆盖模型名（不设则：有 DEEPSEEK_API_KEY 时用 deepseek-chat，否则 gpt-4o-mini）
# LLM_MODEL=deepseek-chat

# 仅 OpenAI 时可用（无 LLM_MODEL 时的回退）
# OPENAI_MODEL=gpt-4o-mini
